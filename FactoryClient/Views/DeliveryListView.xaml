<UserControl x:Class="FactoryClient.Views.DeliveryListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0"
                Background="#F8FAFC"
                BorderBrush="#D6DCE8"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="새로고침"
                            Width="110"
                            Height="34"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Foreground="#475569"
                           FontSize="13"/>
            </DockPanel>
        </Border>

        <!-- 목록 -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="번호" Binding="{Binding DeliveryId}" Width="80"/>
                <DataGridTextColumn Header="납품일" Binding="{Binding DeliveryDate, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                <DataGridTextColumn Header="주문자명" Binding="{Binding CustomerName}" Width="120"/>
                <DataGridTextColumn Header="전화번호" Binding="{Binding PhoneNumber}" Width="140"/>
                <DataGridTextColumn Header="주소" Binding="{Binding Address}" Width="250"/>
                <DataGridTextColumn Header="품목" Binding="{Binding ProductName}" Width="140"/>
                <DataGridTextColumn Header="수량" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="등록일" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 선택 정보 -->
        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#D6DCE8"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="선택 항목"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Top"/>

                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="14" Margin="0,0,0,6">
                        <Run Text="주문자: " FontWeight="Bold"/>
                        <Run Text="{Binding SelectedItem.CustomerName}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,0,0,6">
                        <Run Text="전화번호: " FontWeight="Bold"/>
                        <Run Text="{Binding SelectedItem.PhoneNumber}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,0,0,6">
                        <Run Text="주소: " FontWeight="Bold"/>
                        <Run Text="{Binding SelectedItem.Address}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,0,0,6">
                        <Run Text="품목/수량: " FontWeight="Bold"/>
                        <Run Text="{Binding SelectedItem.ProductName}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SelectedItem.Quantity}"/>
                    </TextBlock>

                    <TextBlock FontSize="13" Foreground="#6B7280">
                        등록 완료된 납품은 수정/삭제하지 않고 취소/반품으로 별도 처리합니다.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>